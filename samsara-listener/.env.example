# ── Telegram credentials ──────────────────────────────────────────────────────
# Get from https://my.telegram.org → API development tools
TG_API_ID=
TG_API_HASH=

# Generated once by running: npx tsx generate-session.ts
# Keep this SECRET — it grants full access to Rebeca's Telegram account
TG_SESSION_STRING=

# Only needed for generate-session.ts (not required in production)
TG_PHONE_NUMBER=+1

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xemjopqbdxgudryiuich.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── SATORI app ────────────────────────────────────────────────────────────────
# Production: your Vercel/Railway URL. Local dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=https://your-satori-app.vercel.app

# Shared secret between this service and /api/samsara/ingest
# Set the same value in SATORI's Vercel environment variables
SAMSARA_INGEST_SECRET=change_me_to_a_random_string
