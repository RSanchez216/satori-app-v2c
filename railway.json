{
  "$schema": "https://railway.app/railway-schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd samsara-listener && npm install"
  },
  "deploy": {
    "startCommand": "cd samsara-listener && npx tsx index.ts",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
